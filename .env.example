# ============================================================
# VeriGuard AI -- Environment Configuration Template
# Copy this file to ".env" and fill in real values.
# NEVER commit your actual .env file.
# ============================================================

# ---------- General ----------
ENVIRONMENT=development            # development | staging | production
APP_NAME=VeriGuard AI
APP_VERSION=0.1.0
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-64-char-string

# ---------- API / Server ----------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# ---------- Auth (OAuth2 / JWT) ----------
JWT_SECRET_KEY=change-me-too
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ---------- Rate Limiting ----------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ---------- PostgreSQL (metadata store) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=veriguard
POSTGRES_USER=veriguard
POSTGRES_PASSWORD=veriguard_dev_password
DATABASE_URL=postgresql+asyncpg://veriguard:veriguard_dev_password@localhost:5432/veriguard

# ---------- Redis (cache / queues) ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---------- Neo4j (network / propagation graph) ----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=veriguard_dev_password

# ---------- Model Registry / Weights ----------
MODEL_REGISTRY_PATH=./models/checkpoints
TEXT_MODEL_NAME=microsoft/deberta-v3-base
SENTENCE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
BLIP2_MODEL_NAME=Salesforce/blip2-opt-2.7b
DEVICE=cpu                          # cpu | cuda | mps

# ---------- External Fact-Checking APIs ----------
GOOGLE_FACTCHECK_API_KEY=
WIKIDATA_ENDPOINT=https://www.wikidata.org/w/api.php
WIKIPEDIA_ENDPOINT=https://en.wikipedia.org/w/api.php
NEWS_API_KEY=

# ---------- MLOps ----------
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=
WANDB_PROJECT=veriguard-ai
DVC_REMOTE_URL=

# ---------- Monitoring ----------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
SENTRY_DSN=

# ---------- Cloud (set per target) ----------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=veriguard-models

AZURE_STORAGE_CONNECTION_STRING=
AZURE_RESOURCE_GROUP=veriguard-rg

GCP_PROJECT_ID=
GCP_STORAGE_BUCKET=veriguard-models
GOOGLE_APPLICATION_CREDENTIALS=

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=VeriGuard AI
